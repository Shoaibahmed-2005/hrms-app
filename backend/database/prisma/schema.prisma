generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  FINALIZED
  PAID
}

enum FaceResetStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  passwordHash        String
  role                Role           @default(EMPLOYEE)
  mustResetPassword   Boolean        @default(true)
  createdAt           DateTime       @default(now())

  employee            Employee?
  reviewedLeaves      LeaveRequest[] @relation("ReviewedLeaves")
  createdAnnouncements Announcement[] @relation("CreatedAnnouncements")
  notifications       Notification[]
}

model Employee {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  employeeCode  String    @unique
  name          String
  phone         String?
  department    String
  designation   String
  dateOfJoining DateTime
  baseSalary    Float
  reportingToId String?
  reportingTo   Employee? @relation("ReportingTo", fields: [reportingToId], references: [id])
  subordinates  Employee[] @relation("ReportingTo")
  status        EmployeeStatus @default(ACTIVE)
  photoUrl      String?

  faceEmbeddings     FaceEmbedding[]
  faceResetRequests  FaceResetRequest[]
  attendanceRecords  AttendanceRecord[]
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[]
  payrollEntries     PayrollEntry[]
  messagesSent       ChatMessage[] @relation("MessagesSent")
  messagesReceived   ChatMessage[] @relation("MessagesReceived")
}

model FaceEmbedding {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  embeddingVector Float[]
  createdAt       DateTime @default(now())
}

model AttendanceRecord {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  date            DateTime @db.Date
  checkInTime     DateTime?
  checkOutTime    DateTime?
  checkInLat      Float?
  checkInLng      Float?
  faceMatchScore  Float?
  status          AttendanceStatus @default(ABSENT)
  hoursWorked     Float?
  isManualOverride Boolean @default(false)
  overrideReason  String?

  @@unique([employeeId, date])
}

model LeaveType {
  id                String   @id @default(uuid())
  name              String   @unique
  defaultAnnualDays Int

  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
}

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  balanceDays Float
  year        Int

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id          String      @id @default(uuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  leaveTypeId String
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  isHalfDay   Boolean     @default(false)
  reason      String?
  status      LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedBy  User?       @relation("ReviewedLeaves", fields: [reviewedById], references: [id])
  reviewComment String?
  createdAt   DateTime    @default(now())
}

model PayrollPeriod {
  id     String        @id @default(uuid())
  month  Int
  year   Int
  status PayrollStatus @default(DRAFT)

  entries PayrollEntry[]

  @@unique([month, year])
}

model PayrollEntry {
  id               String        @id @default(uuid())
  payrollPeriodId  String
  payrollPeriod    PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  employeeId       String
  employee         Employee      @relation(fields: [employeeId], references: [id])
  gross            Float
  leaveDeduction   Float         @default(0)
  halfDayDeduction Float         @default(0)
  overtimePay      Float         @default(0)
  netPay           Float

  @@unique([payrollPeriodId, employeeId])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  body      String
  audience  String   @default("ALL")
  createdById String
  createdBy User     @relation("CreatedAnnouncements", fields: [createdById], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String
  sender     Employee @relation("MessagesSent", fields: [senderId], references: [id])
  receiverId String
  receiver   Employee @relation("MessagesReceived", fields: [receiverId], references: [id])
  message    String
  sentAt     DateTime @default(now())
  readAt     DateTime?
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  action      String
  tableName   String
  recordId    String
  beforeValue String?
  afterValue  String?
  createdAt   DateTime @default(now())
}

model FaceResetRequest {
  id           String          @id @default(uuid())
  employeeId   String
  employee     Employee        @relation(fields: [employeeId], references: [id])
  reason       String
  status       FaceResetStatus @default(PENDING)
  reviewedById String?
  reviewNote   String?
  createdAt    DateTime        @default(now())
}

model CompanySetting {
  id                   String  @id @default("1")
  geofenceLat          Float
  geofenceLng          Float
  geofenceRadiusM      Float   @default(50)
  faceMatchThreshold   Float   @default(0.6)
  shiftStart           String  @default("09:00") // HH:mm format
  shiftEnd             String  @default("17:00")
  overtimeRate         Float   @default(1.5)
  overtimeOffsetsLeave Boolean @default(false)
}
