generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum PayrollStatus {
  DRAFT
  FINALIZED
  PAID
}

enum PaymentType {
  HOURLY
  MONTHLY
}

// ── User (Manager only) ───────────────────────────────────────────────────────

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  passwordHash         String
  role                 Role           @default(MANAGER)
  mustResetPassword    Boolean        @default(false)
  createdAt            DateTime       @default(now())

  createdAnnouncements Announcement[] @relation("CreatedAnnouncements")
  notifications        Notification[]
}

// ── Employee (no login — manager-registered only) ─────────────────────────────

model Employee {
  id            String         @id @default(uuid())
  employeeCode  String         @unique
  name          String
  govtId        String?
  address       String?
  phone         String?
  department    String
  designation   String
  dateOfJoining DateTime
  paymentType   PaymentType    @default(MONTHLY)
  baseSalary    Float?                            // used when paymentType = MONTHLY
  hourlyRate    Float?                            // used when paymentType = HOURLY
  reportingToId String?
  reportingTo   Employee?      @relation("ReportingTo", fields: [reportingToId], references: [id])
  subordinates  Employee[]     @relation("ReportingTo")
  status        EmployeeStatus @default(ACTIVE)
  photoUrl      String?

  faceEmbeddings    FaceEmbedding[]
  attendanceRecords AttendanceRecord[]
  payrollEntries    PayrollEntry[]
}

// ── Face ──────────────────────────────────────────────────────────────────────

model FaceEmbedding {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  embeddingVector Float[]
  createdAt       DateTime @default(now())
}

// ── Attendance ────────────────────────────────────────────────────────────────

model AttendanceRecord {
  id             String           @id @default(uuid())
  employeeId     String
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date           DateTime         @db.Date
  checkInTime    DateTime?
  checkOutTime   DateTime?
  checkInLat     Float?
  checkInLng     Float?
  faceMatchScore Float?
  status         AttendanceStatus @default(ABSENT)
  hoursWorked    Float?
  isHalfDay      Boolean          @default(false)
  dailyEarnings  Float?           // computed on check-out
  extraWages     Float?           // extra pay assigned by manager for this day
  notes          String?

  @@unique([employeeId, date])
}

// ── Payroll ───────────────────────────────────────────────────────────────────

model PayrollPeriod {
  id     String        @id @default(uuid())
  month  Int
  year   Int
  status PayrollStatus @default(DRAFT)

  entries PayrollEntry[]

  @@unique([month, year])
}

model PayrollEntry {
  id              String        @id @default(uuid())
  payrollPeriodId String
  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  totalDays       Int           @default(0)
  fullDays        Int           @default(0)
  halfDays        Int           @default(0)
  totalHours      Float         @default(0)
  totalEarnings   Float         @default(0)
  extraWages      Float         @default(0)
  gross           Float         @default(0)
  netPay          Float         @default(0)

  @@unique([payrollPeriodId, employeeId])
}

// ── Announcements ─────────────────────────────────────────────────────────────

model Announcement {
  id          String   @id @default(uuid())
  title       String
  body        String
  audience    String   @default("ALL")
  createdById String
  createdBy   User     @relation("CreatedAnnouncements", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

// ── Notifications (manager-only) ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // CHECK_IN | CHECK_OUT | LATE | ABSENT | FACE_FAIL | PAYROLL_GENERATED
  message   String
  actionUrl String?  // e.g. "/employees/abc123"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  action      String
  tableName   String
  recordId    String
  beforeValue String?
  afterValue  String?
  createdAt   DateTime @default(now())
}

// ── Company Settings ──────────────────────────────────────────────────────────

model CompanySetting {
  id                    String  @id @default("1")
  faceMatchThreshold    Float   @default(0.60)
  shiftStart            String  @default("09:00")
  shiftEnd              String  @default("17:00")
  halfDayThresholdHours Float   @default(4.0)
  fullDayHours          Float   @default(8.0)
}

